# Operator-supplied / sensitive — never commit.
# (.gitignore does not support trailing comments on a pattern line — keep them
#  on their own lines or the spaces+text become part of the pattern.)

# release binary, CA pubkey, any fetched artifacts
files/

# real fleet inventory with internal IPs (commit inventory/hosts.example.ini only)
inventory/hosts.ini

# per-network group vars may carry internal LB IPs
inventory/group_vars/*.local.yml

*.secret-id
*.retry
